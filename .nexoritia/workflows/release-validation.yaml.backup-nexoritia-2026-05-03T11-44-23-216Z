# Workflow: Release Validation
# Version: 1.0.0
# Description: Validação de release para deploy em produção

workflow:
  name: release-validation
  version: "1.0.0"
  description: Quality gate para deploy de novas versões em ambiente regulado
  
  trigger:
    - type: manual
      actor: "release_manager"
    - type: scheduled
      event: "sprint_end"
    - type: event
      source: "ci_cd_pipeline"
  
  pre_conditions:
    - "Branch estável identificada"
    - "Testes automatizados passaram"
    - "Code review completo"
    - "Documentação atualizada"
  
  stages:
    
    STAGE_1_PRE_FLIGHT:
      name: "Pre-Flight Checks"
      description: "Validações automáticas iniciais"
      automated: true
      
      checks:
        - id: PF-001
          name: "Schema Validation"
          tool: "validate-contracts.mjs"
          blocking: true
        
        - id: PF-002
          name: "Security Scan"
          tool: "security_scanner"
          blocking: true
          checks: ["secrets", "vulnerabilities", "dependencies"]
        
        - id: PF-003
          name: "Test Execution"
          type: "automated"
          blocking: true
          min_coverage: 70
          max_failures: 0
        
        - id: PF-004
          name: "Build Verification"
          type: "automated"
          blocking: true
      
      on_success: "STAGE_2_QUALITY_GATE"
      on_failure: "ABORT_RELEASE"
    
    STAGE_2_QUALITY_GATE:
      name: "Nexoritia Quality Gate"
      description: "Validações de governança"
      
      validations:
        - id: QG-001
          name: "Policy Compliance"
          check: "all_policies_validated"
          files: ".nexoritia/policies/*.yaml"
          blocking: true
        
        - id: QG-002
          name: "Evidence Trail"
          check: "audit_events_complete"
          scope: "since_last_release"
          blocking: true
        
        - id: QG-003
          name: "Regulated Output Check"
          check: "outputs_compliant"
          schema: ".nexoritia/contracts/validation-report.schema.json"
          blocking: true
        
        - id: QG-004
          name: "Documentation Update"
          check: "docs_synced_with_code"
          blocking: false
      
      evidence:
        - validation_report: "generated"
        - hash: "calculated"
        - timestamp: true
      
      on_success: "STAGE_3_CHANGE_ANALYSIS"
      on_failure: "ABORT_RELEASE"
    
    STAGE_3_CHANGE_ANALYSIS:
      name: "Análise de Impacto"
      description: "Avaliar mudanças desde último release"
      
      analysis:
        - "Listar todos os commits"
        - "Identificar arquivos alterados"
        - "Avaliar complexidade"
        - "Identificar riscos"
      
      risk_assessment:
        matrix: ["probabilidade", "impacto"]
        threshold: "MEDIUM"
        
        if_high_risk:
          action: "additional_review"
          by: "technical_lead"
      
      regulatory_impact:
        check: "affects_regulated_features"
        if_yes: "extended_validation"
      
      on_success: "STAGE_4_APPROVAL"
    
    STAGE_4_APPROVAL:
      name: "Aprovação do Release"
      description: "Autorização formal para deploy"
      
      approvers:
        - role: "tech_lead"
          responsibility: "technical_quality"
        - role: "qa_lead"
          responsibility: "testing_completeness"
        - role: "compliance_officer"
          responsibility: "regulatory_compliance"
          condition: "if_regulated_changes"
      
      required_signatures: "all_of_above"
      
      approval_package:
        - change_summary: "generated"
        - risk_assessment: "completed"
        - test_results: "attached"
        - rollback_plan: "documented"
      
      on_approve: "STAGE_5_DEPLOY"
      on_reject: "ABORT_RELEASE"
    
    STAGE_5_DEPLOY:
      name: "Deploy Controlado"
      description: "Implantação em produção"
      
      strategy:
        type: "blue_green"  # ou "canary", "rolling"
        rollback_time: "< 15 minutes"
      
      steps:
        - "Deploy em staging (final check)"
        - "Smoke tests"
        - "Switch traffic (gradual)"
        - "Monitoramento intensivo (30 min)"
        - "All clear ou rollback"
      
      monitoring:
        metrics: ["errors", "latency", "availability"]
        alerts: ["any_anomaly"]
        
        if_anomaly:
          action: "automatic_rollback"
          notification: "immediate"
      
      evidence:
        - deploy_log: "complete"
        - timestamp: "precise"
        - actor: "identified"
      
      on_success: "STAGE_6_POST_DEPLOY"
    
    STAGE_6_POST_DEPLOY:
      name: "Pós-Deploy"
      description: "Validação e estabilização"
      
      monitoring:
        duration: "24h"
        metrics: ["all_system_metrics"]
      
      validation:
        - "Health checks passando"
        - "Usuários conseguem operar"
        - "Sem regressões críticas"
      
      if_validation_passes:
        - "Release notes publicados"
        - "Stakeholders notificados"
        - "Documentação arquivada"
        - "Métricas registradas"
      
      status: "RELEASED"
    
    ABORT_RELEASE:
      name: "Cancelamento"
      description: "Abortar release com documentação"
      
      actions:
        - "Registrar motivo"
        - "Notificar stakeholders"
        - "Preservar evidências"
        - "Planejar correções"
      
      status: "ABORTED"
  
  emergency_procedures:
    hotfix:
      fast_track: true
      required_approvals: 1
      max_deploy_time: "30m"
      post_hoc_review: true
      conditions: ["security_fix", "critical_bug", "compliance_issue"]
    
    rollback:
      trigger: ["critical_error", "regulatory_noncompliance"]
      decision_time: "< 5 minutes"
      method: "automated"
      notification: "immediate"
  
  metrics:
    - "Lead time for release"
    - "Deployment frequency"
    - "Change failure rate"
    - "Mean time to recovery (MTTR)"
    - "Quality gate pass rate"
  
  compliance:
    evidence_retention: "permanent"
    audit_trail: "complete"
    rollback_capability: "mandatory"
