# Policy: AI Generation
# Version: 1.0.0
# Scope: Content generated by AI agents in regulated environments

policy:
  name: ai-generation
  description: Regras para geração de conteúdo por IA em ambientes regulados
  version: "1.0.0"
  effective_date: "2025-01-15"

  principles:
    - name: HUMAN_IN_THE_LOOP
      description: "IA auxilia, humano decide"
      priority: 1
    
    - name: EVIDENCE_BASED
      description: "Toda geração deixa rastro"
      priority: 2
    
    - name: VALIDATION_REQUIRED
      description: "Nenhum output regulado sem validação"
      priority: 3
    
    - name: NO_HALLUCINATION
      description: "Fatos verificáveis apenas"
      priority: 4

  allowed_content_types:
    - SOP_STRUCTURE:
        description: "Estrutura e template de SOPs"
        human_review: REQUIRED
    - TRAINING_MATERIAL:
        description: "Material de apoio para treinamentos"
        human_review: REQUIRED
    - QUIZ_QUESTIONS:
        description: "Questões de avaliação"
        human_review: REQUIRED
    - DOCUMENTATION:
        description: "Comentários e documentação técnica"
        human_review: RECOMMENDED
    - CODE_COMMENTS:
        description: "Comentários em código"
        human_review: OPTIONAL

  prohibited_content_types:
    - FINAL_APPROVAL:
        description: "Aprovação final de documentos regulados"
        reason: "Requer assinatura humana"
    - REGULATORY_INTERPRETATION:
        description: "Interpretação de normas regulatórias"
        reason: "Requer expertise legal"
    - CLINICAL_DECISION:
        description: "Decisões clínicas ou de pacientes"
        reason: "Requer licença médica"
    - SAFETY_CRITICAL:
        description: "Instruções de segurança críticas"
        reason: "Requer validação especializada"

  quality_gates:
    mandatory:
      - SCHEMA_VALIDATION:
          description: "Validar contra schema JSON"
          tool: "validate-contracts.mjs"
          blocking: true
      
      - FACT_CHECK:
          description: "Verificar fatos contra fontes confiáveis"
          method: "rag_verification"
          blocking: false
      
      - CLARITY_SCORE:
          description: "Score de legibilidade mínimo"
          threshold: 60
          method: "flesch_reading_ease"
          blocking: false
      
      - TECHNICAL_ACCURACY:
          description: "Termos técnicos validados"
          method: "ontology_check"
          blocking: true

  evidence_requirements:
    log_entries:
      - timestamp
      - prompt_used
      - model_version
      - output_hash
      - validation_results
      - human_reviewer_id
    
    retention: "5_years"
    format: "immutable_audit_trail"

  prompt_engineering:
    required_elements:
      - "Contexto claro do domínio"
      - "Referências a documentos base"
      - "Restrições explícitas"
      - "Formato de saída definido"
    
    prohibited_patterns:
      - "Pedidos vagos ou abertos"
      - "Solicitação de decisões finais"
      - "Geração sem contexto de compliance"

  model_requirements:
    temperature:
      sop_generation: 0.3
      code_generation: 0.2
      documentation: 0.4
    
    max_tokens:
      sop: 4000
      training_material: 3000
      quiz: 2000
      code: 2000
    
    fallback:
      on_rate_limit: "queue_for_retry"
      on_error: "use_local_skill"

  hallucination_prevention:
    fact_verification:
      enabled: true
      sources: ["internal_kb", "anvisa_db", "farmacia_brasileira"]
      threshold: 0.85
    
    uncertainty_handling:
      strategy: "flag_for_review"
      never_guess: true

  compliance_alignment:
    anvisa_bpf:
      required_mentions:
        - "RDC 67/2007"
        - "Boas Práticas de Fabricação"
      prohibited_content:
        - "Informação médica não verificada"
        - "Procedimentos não validados"
    
    data_privacy:
      lgpd_compliance: true
      no_phi_in_prompts: true
      anonymization: "default"

  review_workflow:
    generated_content:
      - step: "AI_GENERATION"
        duration: "immediate"
      - step: "AUTOMATED_VALIDATION"
        duration: "< 5s"
      - step: "HUMAN_REVIEW"
        duration: "24h"
        assignee: "subject_matter_expert"
      - step: "APPROVAL"
        duration: "48h"
        assignee: "quality_manager"
      - step: "PUBLISH"
        duration: "immediate"

  error_handling:
    on_validation_failure:
      action: "REJECT_AND_NOTIFY"
      retry: false
      escalate_to: "quality_team"
    
    on_human_rejection:
      action: "LEARN_AND_FLAG"
      update_model: false
      log_pattern: true

  metrics:
    track:
      - "Acceptance rate"
      - "Validation pass rate"
      - "Human review time"
      - "Hallucination incidents"
      - "Compliance score"
    
    report_periodicity: "weekly"
