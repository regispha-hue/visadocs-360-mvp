{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Nexoritia SOP",
  "type": "object",
  "required": [
    "id",
    "title",
    "version",
    "status",
    "owner",
    "sections"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "enum": [
        "draft",
        "review",
        "approved",
        "retired"
      ]
    },
    "owner": {
      "type": "string"
    },
    "reviewer": {
      "type": "string"
    },
    "approvalDate": {
      "type": "string"
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}