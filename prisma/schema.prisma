generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN_FARMACIA
  RT
  ANALISTA_CQ
  OPERADOR
}

enum TenantStatus {
  PENDENTE
  ATIVO
  SUSPENSO
  CANCELADO
}

enum SubscriptionStatus {
  TRIAL
  ATIVO
  SUSPENSO
  CANCELADO
}

enum PopStatus {
  RASCUNHO
  ATIVO
  ARQUIVADO
}

enum ColaboradorStatus {
  ATIVO
  INATIVO
}

enum TreinamentoStatus {
  PENDENTE
  EM_AVALIACAO
  CONCLUIDO
}

enum DocumentoTipo {
  RQ
  MBP
  ANEXO
}

enum MateriaPrimaStatus {
  ATIVO
  INATIVO
  DESCONTINUADO
}

enum LoteStatus {
  QUARENTENA
  APROVADO
  REPROVADO
  VENCIDO
  EM_USO
  ESGOTADO
}

model Tenant {
  id                 String             @id @default(uuid())
  nome               String
  cnpj               String             @unique
  responsavel        String
  email              String             @unique
  telefone           String
  endereco           Json
  status             TenantStatus       @default(PENDENTE)
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  trialEndsAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  users              User[]
  pops               Pop[]
  colaboradores      Colaborador[]
  treinamentos       Treinamento[]
  auditLogs          AuditLog[]
  materiasPrimas     MateriaPrima[]
  lotes              Lote[]
  fornecedores       Fornecedor[]
  documentos         Documento[]
  quizzes            Quiz[]

  alertas AlertaNorma[]

  verificacoesPraticas VerificacaoPratica[]

  auditoriasFiscalizacao AuditoriaFiscalizacao[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  role      UserRole
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model Pop {
  id                  String          @id @default(uuid())
  codigo              String
  titulo              String
  setor               String
  versao              String
  dataRevisao         DateTime
  responsavel         String
  objetivo            String
  descricao           String
  equipeEnvolvida     String?
  glossario           String?
  literaturaConsultada String?
  controleAlteracoes  Json?
  validadoEm          DateTime?
  validadoPor         String?
  implantadoEm        DateTime?
  implantadoPor       String?
  validadeAnos        Int?            @default(2)
  arquivoUrl          String?
  arquivoNome         String?
  arquivoPublic       Boolean         @default(false)
  docxGerado          Boolean         @default(false)
  status              PopStatus       @default(RASCUNHO)
  tenantId            String
  tenant              Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  treinamentos        Treinamento[]
  materiasPrimas      PopMateriaPrima[]
  documentos          Documento[]
  quiz                Quiz?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  riscos Risco[]

  naoConformidades NaoConformidade[]

  verificacoesPraticas VerificacaoPratica[]

  @@unique([tenantId, codigo])
  @@index([tenantId])
  @@index([setor])
  @@index([status])
}

model Colaborador {
  id           String            @id @default(uuid())
  nome         String
  cpfHash      String
  cpfMasked    String
  funcao       String
  setor        String
  dataAdmissao DateTime
  email        String?
  status       ColaboradorStatus @default(ATIVO)
  tenantId     String
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  treinamentos   Treinamento[]
  tentativasQuiz TentativaQuiz[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  verificacoesPraticas VerificacaoPratica[]

  @@unique([tenantId, cpfHash])
  @@index([tenantId])
  @@index([funcao])
  @@index([status])
}

model Treinamento {
  id              String            @id @default(uuid())
  popId           String
  pop             Pop               @relation(fields: [popId], references: [id], onDelete: Cascade)
  colaboradorId   String
  colaborador     Colaborador       @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  dataTreinamento DateTime
  instrutor       String
  duracao         Float?
  observacoes     String?
  notaQuiz        Float?
  aprovadoQuiz    Boolean?
  status          TreinamentoStatus @default(CONCLUIDO)
  tenantId        String
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tentativasQuiz  TentativaQuiz[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  naoConformidades NaoConformidade[]

  verificacoesPraticas VerificacaoPratica[]

  @@index([tenantId])
  @@index([popId])
  @@index([colaboradorId])
  @@index([status])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String?
  userId    String?
  userName  String?
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  details   Json?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([action])
  @@index([createdAt])
}

model Fornecedor {
  id            String         @id @default(uuid())
  nome          String
  cnpj          String?
  email         String?
  telefone      String?
  endereco      String?
  contato       String?
  observacoes   String?
  ativo         Boolean        @default(true)
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  materiasPrimas MateriaPrima[]
  lotes         Lote[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([tenantId, cnpj])
  @@index([tenantId])
  @@index([ativo])
}

model MateriaPrima {
  id                 String             @id @default(uuid())
  codigo             String
  nome               String
  descricao          String?
  casNumber          String?
  dci                String?
  categoria          String?
  unidadeMedida      String
  estoqueMinimo      Float?
  especificacoes     Json?
  certificadoUrl     String?
  certificadoNome    String?
  certificadoPublic  Boolean            @default(false)
  status             MateriaPrimaStatus @default(ATIVO)
  fornecedorId       String?
  fornecedor         Fornecedor?        @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)
  tenantId           String
  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lotes              Lote[]
  pops               PopMateriaPrima[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([tenantId, codigo])
  @@index([tenantId])
  @@index([fornecedorId])
  @@index([status])
  @@index([categoria])
}

model Lote {
  id                String      @id @default(uuid())
  numeroLote        String
  loteInterno       String?
  dataFabricacao    DateTime?
  dataValidade      DateTime
  dataRecebimento   DateTime
  quantidade        Float
  quantidadeAtual   Float
  precoUnitario     Float?
  notaFiscal        String?
  certificadoUrl    String?
  certificadoNome   String?
  certificadoPublic Boolean     @default(false)
  laudoUrl          String?
  laudoNome         String?
  laudoPublic       Boolean     @default(false)
  analises          Json?
  observacoes       String?
  status            LoteStatus  @default(QUARENTENA)
  materiaPrimaId    String
  materiaPrima      MateriaPrima @relation(fields: [materiaPrimaId], references: [id], onDelete: Cascade)
  fornecedorId      String?
  fornecedor        Fornecedor?  @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)
  tenantId          String
  tenant            Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([tenantId, numeroLote, materiaPrimaId])
  @@index([tenantId])
  @@index([materiaPrimaId])
  @@index([fornecedorId])
  @@index([status])
  @@index([dataValidade])
}

model PopMateriaPrima {
  id             String       @id @default(uuid())
  popId          String
  pop            Pop          @relation(fields: [popId], references: [id], onDelete: Cascade)
  materiaPrimaId String
  materiaPrima   MateriaPrima @relation(fields: [materiaPrimaId], references: [id], onDelete: Cascade)
  quantidade     Float?
  observacoes    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([popId, materiaPrimaId])
  @@index([popId])
  @@index([materiaPrimaId])
}

model Documento {
  id          String        @id @default(uuid())
  codigo      String
  titulo      String
  tipo        DocumentoTipo
  categoria   String
  conteudo    String
  versao      String        @default("Rev00")
  popId       String?
  pop         Pop?          @relation(fields: [popId], references: [id], onDelete: SetNull)
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([tenantId, codigo])
  @@index([tenantId])
  @@index([tipo])
  @@index([popId])
}

model Quiz {
  id          String          @id @default(uuid())
  popId       String          @unique
  pop         Pop             @relation(fields: [popId], references: [id], onDelete: Cascade)
  titulo      String
  descricao   String?
  notaMinima  Float           @default(70)
  ativo       Boolean         @default(true)
  questoes    Questao[]
  tentativas  TentativaQuiz[]
  tenantId    String
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([tenantId])
  @@index([popId])
}

model Questao {
  id           String          @id @default(uuid())
  quizId       String
  quiz         Quiz            @relation(fields: [quizId], references: [id], onDelete: Cascade)
  pergunta     String
  ordem        Int
  alternativas Alternativa[]
  respostas    RespostaQuiz[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([quizId])
}

model Alternativa {
  id        String         @id @default(uuid())
  questaoId String
  questao   Questao        @relation(fields: [questaoId], references: [id], onDelete: Cascade)
  texto     String
  correta   Boolean        @default(false)
  ordem     Int
  respostas RespostaQuiz[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([questaoId])
}

model TentativaQuiz {
  id              String         @id @default(uuid())
  quizId          String
  quiz            Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  colaboradorId   String
  colaborador     Colaborador    @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  treinamentoId   String
  treinamento     Treinamento    @relation(fields: [treinamentoId], references: [id], onDelete: Cascade)
  nota            Float
  aprovado        Boolean
  totalQuestoes   Int
  acertos         Int
  codigoValidacao String?
  respostas       RespostaQuiz[]
  completadoEm    DateTime       @default(now())
  createdAt       DateTime       @default(now())

  @@index([quizId])
  @@index([colaboradorId])
  @@index([treinamentoId])
}

model RespostaQuiz {
  id            String        @id @default(uuid())
  tentativaId   String
  tentativa     TentativaQuiz @relation(fields: [tentativaId], references: [id], onDelete: Cascade)
  questaoId     String
  questao       Questao       @relation(fields: [questaoId], references: [id], onDelete: Cascade)
  alternativaId String
  alternativa   Alternativa   @relation(fields: [alternativaId], references: [id], onDelete: Cascade)
  correta       Boolean
  createdAt     DateTime      @default(now())

  @@index([tentativaId])
  @@index([questaoId])
}

// ISO 9001:2015 - Gestão da Qualidade e Riscos
enum StatusRisco {
  IDENTIFICADO
  MITIGADO
  MONITORADO
  CRITICO
  ACEITO
}

enum TipoRisco {
  OPERACIONAL
  REGULATORIO
  QUALIDADE
  SEGURANCA
  FINANCEIRO
}

enum SeveridadeRisco {
  BAIXO
  MEDIO
  ALTO
  CRITICO
}

enum StatusNaoConformidade {
  ABERTA
  EM_ANALISE
  CORRECAO_PENDENTE
  CORRIGIDA
  VERIFICADA
  FECHADA
}

enum StatusAuditoria {
  PLANEJADA
  EM_ANDAMENTO
  CONCLUIDA
  CANCELADA
}

model Risco {
  id               String         @id @default(uuid())
  tenantId         String
  descricao        String
  setor            String
  categoria        String?
  probabilidade    Int            // 1 a 5
  impacto          Int            // 1 a 5
  nivelRisco       Int            // Cálculo automático: Prob x Impacto
  tipo             TipoRisco
  severidade       SeveridadeRisco
  status           StatusRisco    @default(IDENTIFICADO)
  
  // Vinculação com POPs existentes
  popId            String?
  pop              Pop?           @relation(fields: [popId], references: [id], onDelete: SetNull)
  
  // Plano de ação
  planoAcao        String?
  responsavelPlano String?
  prazoPlano       DateTime?
  dataMitigacao    DateTime?
  
  // Análise de impacto
  impactoFinanceiro Float?
  impactoReputacional Float?
  impactoLegal     Float?
  
  // Histórico
  criadoPor        String?
  criadoEm         DateTime       @default(now())
  atualizadoPor    String?
  atualizadoEm     DateTime       @updatedAt
  
  // Relacionamentos
  naoConformidades NaoConformidade[]
  auditorias       AuditoriaRisco[]
  
  @@index([tenantId])
  @@index([setor])
  @@index([tipo])
  @@index([status])
  @@index([nivelRisco])
  @@index([popId])
}

model NaoConformidade {
  id               String               @id @default(uuid())
  tenantId         String
  codigo           String               @unique
  titulo           String
  descricao        String
  setor            String?
  
  // Classificação
  tipo             String               // "Desvio de POP", "Não conformidade", "Oportunidade"
  severidade       SeveridadeRisco
  status           StatusNaoConformidade @default(ABERTA)
  
  // Origem
  origem           String               // "Auditoria", "Fiscalização", "Denúncia", "Rotina"
  dataOcorrencia   DateTime
  dataIdentificacao DateTime             @default(now())
  
  // Responsáveis
  reportadoPor     String
  responsavelAnalise String?
  responsavelCorrecao String?
  
  // Análise
  causaRaiz        String?
  analiseCausa     Json?                 // Análise detalhada
  impacto          String?
  
  // Ações corretivas
  acoesCorretivas  String[]
  prazoCorrecao    DateTime?
  dataConclusao    DateTime?
  
  // Verificação
  verificacao      String?
  dataVerificacao  DateTime?
  eficacia         Boolean?
  
  // Relacionamentos
  riscoId          String?
  risco            Risco?               @relation(fields: [riscoId], references: [id], onDelete: SetNull)
  popId            String?
  pop              Pop?                 @relation(fields: [popId], references: [id], onDelete: SetNull)
  treinamentos     Treinamento[]
  
  // Anexos
  anexos           Json?                 // URLs de documentos
  
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  
  @@index([tenantId])
  @@index([codigo])
  @@index([status])
  @@index([severidade])
  @@index([dataOcorrencia])
  @@index([riscoId])
  @@index([popId])
}

model AuditoriaRisco {
  id               String         @id @default(uuid())
  tenantId         String
  titulo           String
  descricao        String?
  tipo             String         // "Interna", "Externa", "Fiscalização"
  status           StatusAuditoria @default(PLANEJADA)
  
  // Período
  dataInicio       DateTime
  dataFim          DateTime?
  
  // Equipe
  auditorLider     String
  auditores        String[]       // Nomes dos auditores
  
  // Escopo
  setores          String[]       // Setores auditados
  pops             String[]       // POPs verificados
  criterios        Json?          // Critérios de auditoria
  
  // Resultados
  resultado        String?        // "Conforme", "Não conforme", "Parcialmente conforme"
  pontuacao        Float?         // Score geral
  naoConformidades String[]       // Códigos das NCs encontradas
  
  // Relatório
  relatorioUrl     String?
  relatorioNome    String?
  dataEntrega      DateTime?
  
  // Ações
  planoAcao       String?
  prazoAcao       DateTime?
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  
  // Relacionamentos
  riscoId          String?
  risco            Risco?         @relation(fields: [riscoId], references: [id], onDelete: SetNull)
  
  @@index([tenantId])
  @@index([status])
  @@index([dataInicio])
  @@index([tipo])
  @@index([riscoId])
}

// Inteligência Regulatória Ativa
enum StatusNorma {
  ATIVA
  REVOGADA
  ATUALIZADA
  EM_REVISAO
}

enum TipoAtualizacao {
  NOVA_NORMA
  ALTERACAO
  REVOGACAO
  ORIENTACAO
}

model NormaRegulatoria {
  id               String         @id @default(uuid())
  numero           String         // "RDC 67/2007"
  titulo           String
  tipo             String         // "RDC", "Portaria", "Resolução"
  orgao            String         // "ANVISA", "Ministério da Saúde"
  status           StatusNorma    @default(ATIVA)
  
  // Conteúdo
  ementa           String?
  conteudo         String?
  urlOficial       String?
  
  // Datas
  dataPublicacao   DateTime
  dataVigencia     DateTime?
  dataRevogacao    DateTime?
  
  // Categorias
  categorias       String[]       // ["Manipulação", "Qualidade", "Segurança"]
  aplicabilidade   String[]       // ["Farmácias", "Distribuidoras", "Laboratórios"]
  
  // Impacto nos POPs
  popsImpactados   String[]       // Códigos dos POPs afetados
  requisitos       Json?          // Requisitos específicos
  
  // Análise de impacto
  nivelImpacto     Int            // 1 a 5
  complexidade    Int            // 1 a 5
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  
  // Relacionamentos
  atualizacoes     AtualizacaoNorma[]
  alertas          AlertaNorma[]
  
  @@index([numero])
  @@index([tipo])
  @@index([status])
  @@index([dataPublicacao])
}

model AtualizacaoNorma {
  id               String         @id @default(uuid())
  normaId          String
  norma            NormaRegulatoria @relation(fields: [normaId], references: [id], onDelete: Cascade)
  
  tipo             TipoAtualizacao
  descricao        String
  detalhes         Json?          // Detalhes da mudança
  
  // Datas
  dataDeteccao     DateTime       @default(now())
  dataPublicacao   DateTime?
  dataVigencia     DateTime?
  
  // Análise de impacto
  impactoPOPs      String[]       // POPs afetados
  acoesNecessarias String[]       // Ações recomendadas
  
  // Status
  status           String         // "Detectada", "Analisando", "Comunicada", "Implementada"
  
  // Responsável
  detectadoPor     String?        // "Sistema IA", "Equipe", "Usuário"
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  
  @@index([normaId])
  @@index([tipo])
  @@index([dataDeteccao])
  @@index([status])
}

model AlertaNorma {
  id               String         @id @default(uuid())
  normaId          String
  norma            NormaRegulatoria @relation(fields: [normaId], references: [id], onDelete: Cascade)
  atualizacaoId    String?
  
  tenantId         String
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Conteúdo do alerta
  titulo           String
  mensagem         String
  tipo             String         // "CRÍTICO", "ALERTA", "INFORMATIVO"
  prioridade       Int            // 1 a 5
  
  // Análise de impacto
  popsAfetados     String[]       // Códigos dos POPs afetados
  setoresAfetados  String[]       // Setores impactados
  impactoOperacional String?
  
  // Ações recomendadas
  acoesRecomendadas String[]
  prazoAcao        DateTime?
  
  // Status
  status           String         // "NOVO", "LIDO", "EM_ANALISE", "RESOLVIDO"
  dataLeitura      DateTime?
  dataResolucao    DateTime?
  
  // Responsáveis
  responsavel      String?
  notificadoPor    String?
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  
  @@index([tenantId])
  @@index([normaId])
  @@index([status])
  @@index([prioridade])
  @@index([createdAt])
}

// Prova de Competência Prática
enum StatusVerificacaoPratica {
  PENDENTE
  AGENDADO
  EM_ANDAMENTO
  APROVADO
  REPROVADO
  CANCELADO
}

model VerificacaoPratica {
  id               String               @id @default(uuid())
  tenantId         String
  tenant           Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Vinculação
  treinamentoId    String
  treinamento      Treinamento         @relation(fields: [treinamentoId], references: [id], onDelete: Cascade)
  colaboradorId    String
  colaborador      Colaborador         @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  popId            String
  pop              Pop                 @relation(fields: [popId], references: [id], onDelete: Cascade)
  
  // Agendamento
  dataAgendamento  DateTime
  duracaoEstimada  Int?                 // minutos
  
  // Verificação
  status           StatusVerificacaoPratica @default(PENDENTE)
  supervisor       String               // Nome do supervisor
  resultado        String?              // "APROVADO", "REPROVADO", "PARCIAL"
  nota             Float?               // 0 a 10
  
  // Checklist de verificação
  checklist        Json?                // Itens verificados
  observacoes      String?
  pontosCriticos   String?              // Pontos que precisaram atenção
  
  // Evidências
  fotosUrl         String[]             // URLs das fotos/vídeos
  assinaturaSupervisor String?          // Assinatura digital
  
  // Datas
  dataInicio       DateTime?
  dataConclusao    DateTime?
  
  // Retreinamento
  precisaRetreinamento Boolean         @default(false)
  dataRetreinamento DateTime?
  
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  
  @@index([tenantId])
  @@index([treinamentoId])
  @@index([colaboradorId])
  @@index([popId])
  @@index([status])
  @@index([dataAgendamento])
}

// Botão de Pânico - Modo Fiscalização
enum StatusAuditoriaFiscalizacao {
  ATIVO
  INATIVO
  EXPIRADO
}

model AuditoriaFiscalizacao {
  id               String               @id @default(uuid())
  tenantId         String
  tenant           Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Configuração
  qrCode           String               // QR Code para acesso
  codigoAcesso     String               // Código de acesso alternativo
  status           StatusAuditoriaFiscalizacao @default(ATIVO)
  
  // Período de validade
  dataGeracao      DateTime             @default(now())
  dataExpiracao    DateTime
  
  // Responsáveis autorizados
  responsaveis      String[]             // Nomes/Cargos autorizados
  
  // Conteúdo da auditoria
  masterListPOPs   Json                 // POPs ativos e versões
  certificados     Json                 // Certificados de treinamento válidos
  cronogramaValidades Json             // Validades de documentos
  
  // Logs de acesso
  acessos          Json?                // Histórico de acessos
  
  // Configurações de segurança
  ipRestritos      String[]             // IPs permitidos (opcional)
  horarioFuncionamento Json?            // Horários permitidos
  
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  
  @@index([tenantId])
  @@index([qrCode])
  @@index([status])
  @@index([dataExpiracao])
}


model Subscription {
  id                   String    @id @default(cuid())
  tenantId             String
  tenant               Tenant    @relation(fields: [tenantId], references: [id])
  planId               String
  plan                 Plan      @relation(fields: [planId], references: [id])
  status               String    @default("active")
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelledAt          DateTime?
  stripeSubscriptionId String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model Plan {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  price         Float
  currency      String         @default("BRL")
  interval      String         @default("month")
  features      Json?
  maxUsers      Int            @default(1)
  isActive      Boolean        @default(true)
  stripePriceId String?
  subscriptions Subscription[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Payment {
  id               String   @id @default(cuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  amount           Float
  currency         String   @default("BRL")
  status           String   @default("pending")
  method           String?
  stripePaymentId  String?
  description      String?
  paidAt           DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model SecurityLog {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String?
  action    String
  ip        String?
  userAgent String?
  details   Json?
  severity  String   @default("info")
  createdAt DateTime @default(now())
}

model Alerta {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  type      String
  title     String
  message   String?
  severity  String   @default("info")
  isRead    Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())
}

model Certificado {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  clienteId   String?
  type        String
  title       String
  description String?
  fileUrl     String?
  expiresAt   DateTime?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CargoModelo {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  template    Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WebhookLog {
  id        String   @id @default(cuid())
  source    String
  event     String
  payload   Json?
  status    String   @default("received")
  error     String?
  createdAt DateTime @default(now())
}
