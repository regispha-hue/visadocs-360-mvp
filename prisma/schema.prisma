generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  role      String   @default("OPERADOR")
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tenant {
  id                               String                            @id @default(cuid())
  nome                             String
  cnpj                             String?
  responsavel                      String?
  email                            String?
  telefone                         String?
  endereco                         String?
  status                           String                            @default("ATIVO")
  subscriptionStatus               String                            @default("ATIVO")
  trialEndsAt                      DateTime?
  logoUrl                          String?
  createdAt                        DateTime                          @default(now())
  updatedAt                        DateTime                          @updatedAt
  users                            User[]
  pops                             Pop[]
  colaboradores                    Colaborador[]
  treinamentos                     Treinamento[]
  auditLogs                        AuditLog[]
  auditoriasFiscalizacao           AuditoriaFiscalizacao[]
  quizzes                          Quiz[]
  documentos                       Documento[]
  fornecedores                     Fornecedor[]
  materiasPrimas                   MateriaPrima[]
  lotes                            Lote[]
  popMateriasPrimas                PopMateriaPrima[]
  riscos                           Risco[]
  naoConformidades                 NaoConformidade[]
  auditorias                       Auditoria[]
  auditoriasRisco                  AuditoriaRisco[]
  normas                           Norma[]
  alertasNorma                     AlertaNorma[]
  verificacoesPratica              VerificacaoPratica[]
  documentaryLibraryItems          DocumentaryLibraryItem[]
  assistedPopDrafts                AssistedPopDraft[]
  approvedPopVersions              ApprovedPopVersion[]
  rtApprovalEvents                 RTApprovalEvent[]
  documentLifecycleEvents          DocumentLifecycleEvent[]
  canonicalIngestionJobs           CanonicalIngestionJob[]
  canonicalDocuments               CanonicalDocument[]
  canonicalChunks                  CanonicalChunk[]
  ragRetrievalLogs                 RagRetrievalLog[]
  assistedPopDraftCanonicalSources AssistedPopDraftCanonicalSource[]
  documentoImpressaoLogs           DocumentoImpressaoLog[]
  certificados                     Certificado[]
  alertasTreinamento               AlertaTreinamento[]
}

model Pop {
  id                   String                   @id @default(cuid())
  codigo               String                   @unique
  titulo               String
  setor                String?
  status               String                   @default("ATIVO")
  versao               String                   @default("1.0")
  validadeAnos         Int                      @default(2)
  validadoEm           DateTime?
  validadoPor          String?
  implantadoEm         DateTime?
  implantadoPor        String?
  dataRevisao          DateTime?
  responsavel          String?
  objetivo             String?
  descricao            String?
  equipeEnvolvida      String?
  glossario            String?
  literaturaConsultada String?
  conteudo             String?
  arquivoUrl           String?
  arquivoNome          String?
  arquivoPublic        Boolean                  @default(false)
  tenantId             String
  tenant               Tenant                   @relation(fields: [tenantId], references: [id])
  treinamentos         Treinamento[]
  libraryItems         DocumentaryLibraryItem[]
  assistedDrafts       AssistedPopDraft[]
  approvedVersions     ApprovedPopVersion[]
  rtApprovalEvents     RTApprovalEvent[]
  quizzes              Quiz[]
  documentos           Documento[]
  popMateriasPrimas    PopMateriaPrima[]
  riscos               Risco[]
  naoConformidades     NaoConformidade[]
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
}

model Colaborador {
  id                  String               @id @default(cuid())
  nome                String
  email               String?
  funcao              String?
  setor               String?
  cpf                 String?
  cpfHash             String?
  cpfMasked           String?
  dataAdmissao        DateTime?
  status              String               @default("ATIVO")
  tenantId            String
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  treinamentos        Treinamento[]
  tentativas          TentativaQuiz[]
  verificacoesPratica VerificacaoPratica[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model Treinamento {
  id                   String               @id @default(cuid())
  popId                String
  pop                  Pop                  @relation(fields: [popId], references: [id])
  approvedPopVersionId String?
  approvedPopVersion   ApprovedPopVersion?  @relation(fields: [approvedPopVersionId], references: [id])
  popCodigoSnapshot    String?
  popTituloSnapshot    String?
  popVersaoSnapshot    String?
  colaboradorId        String
  colaborador          Colaborador          @relation(fields: [colaboradorId], references: [id])
  dataTreinamento      DateTime
  duracao              Int?
  instrutor            String?
  observacoes          String?
  notaQuiz             Int?
  aprovadoQuiz         Boolean?
  status               String
  tenantId             String
  tenant               Tenant               @relation(fields: [tenantId], references: [id])
  tentativas           TentativaQuiz[]
  verificacoesPratica  VerificacaoPratica[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([tenantId, popId])
  @@index([tenantId, approvedPopVersionId])
}

model DocumentaryLibraryItem {
  id                 String                   @id @default(cuid())
  tenantId           String
  tenant             Tenant                   @relation(fields: [tenantId], references: [id])
  type               String
  title              String
  code               String?
  category           String?
  status             String                   @default("ACTIVE")
  version            String?
  content            String?
  fileUrl            String?
  source             String?
  sourcePopId        String?
  sourcePop          Pop?                     @relation(fields: [sourcePopId], references: [id])
  createdByUserId    String?
  createdByUserName  String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  draftSources       AssistedPopDraftSource[]
  canonicalDocuments CanonicalDocument[]
  impressaoLogs      DocumentoImpressaoLog[]

  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([tenantId, category])
  @@index([tenantId, sourcePopId])
}

model DocumentoImpressaoLog {
  id          String                 @id @default(cuid())
  documentoId String
  documento   DocumentaryLibraryItem @relation(fields: [documentoId], references: [id])
  usuarioId   String
  usuarioNome String?
  tipo        String
  tenantId    String
  tenant      Tenant                 @relation(fields: [tenantId], references: [id])
  criadoEm    DateTime               @default(now())

  @@index([tenantId, documentoId])
  @@index([tenantId, criadoEm])
  @@index([tenantId, usuarioId])
}

model AssistedPopDraft {
  id                  String                            @id @default(cuid())
  tenantId            String
  tenant              Tenant                            @relation(fields: [tenantId], references: [id])
  popId               String?
  pop                 Pop?                              @relation(fields: [popId], references: [id])
  title               String
  code                String?
  status              String                            @default("RASCUNHO")
  version             String                            @default("0.1")
  objective           String?
  content             String?
  notes               String?
  submittedAt         DateTime?
  submittedByUserId   String?
  submittedByUserName String?
  createdByUserId     String?
  createdByUserName   String?
  createdAt           DateTime                          @default(now())
  updatedAt           DateTime                          @updatedAt
  sources             AssistedPopDraftSource[]
  canonicalSources    AssistedPopDraftCanonicalSource[]
  approvedVersions    ApprovedPopVersion[]
  approvalEvents      RTApprovalEvent[]

  @@index([tenantId, status])
  @@index([tenantId, popId])
  @@index([tenantId, createdAt])
}

model AssistedPopDraftSource {
  id            String                 @id @default(cuid())
  tenantId      String
  draftId       String
  draft         AssistedPopDraft       @relation(fields: [draftId], references: [id])
  libraryItemId String
  libraryItem   DocumentaryLibraryItem @relation(fields: [libraryItemId], references: [id])
  sourceTitle   String?
  sourceVersion String?
  createdAt     DateTime               @default(now())

  @@unique([draftId, libraryItemId])
  @@index([tenantId, draftId])
  @@index([tenantId, libraryItemId])
}

model AssistedPopDraftCanonicalSource {
  id                  String            @id @default(cuid())
  tenantId            String
  tenant              Tenant            @relation(fields: [tenantId], references: [id])
  assistedPopDraftId  String
  assistedPopDraft    AssistedPopDraft  @relation(fields: [assistedPopDraftId], references: [id])
  canonicalDocumentId String
  canonicalDocument   CanonicalDocument @relation(fields: [canonicalDocumentId], references: [id])
  canonicalChunkId    String
  canonicalChunk      CanonicalChunk    @relation(fields: [canonicalChunkId], references: [id])
  ragRetrievalLogId   String?
  ragRetrievalLog     RagRetrievalLog?  @relation(fields: [ragRetrievalLogId], references: [id])
  chunkIndex          Int
  sourceTextPreview   String
  sourceHash          String
  createdAt           DateTime          @default(now())

  @@unique([assistedPopDraftId, canonicalChunkId])
  @@index([tenantId, assistedPopDraftId])
  @@index([tenantId, canonicalChunkId])
  @@index([tenantId, canonicalDocumentId])
  @@index([tenantId, ragRetrievalLogId])
}

model ApprovedPopVersion {
  id                 String              @id @default(cuid())
  tenantId           String
  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  popId              String
  pop                Pop                 @relation(fields: [popId], references: [id])
  draftId            String?
  draft              AssistedPopDraft?   @relation(fields: [draftId], references: [id])
  code               String
  title              String
  version            String
  status             String              @default("CURRENT")
  contentSnapshot    String?
  approvedByUserId   String
  approvedByUserName String?
  approvedAt         DateTime            @default(now())
  obsoleteAt         DateTime?
  createdAt          DateTime            @default(now())
  treinamentos       Treinamento[]
  approvalEvents     RTApprovalEvent[]
  canonicalDocuments CanonicalDocument[]

  @@unique([tenantId, popId, version])
  @@index([tenantId, popId])
  @@index([tenantId, status])
  @@index([tenantId, approvedAt])
}

model RTApprovalEvent {
  id                   String              @id @default(cuid())
  tenantId             String
  tenant               Tenant              @relation(fields: [tenantId], references: [id])
  popId                String
  pop                  Pop                 @relation(fields: [popId], references: [id])
  draftId              String?
  draft                AssistedPopDraft?   @relation(fields: [draftId], references: [id])
  approvedPopVersionId String?
  approvedPopVersion   ApprovedPopVersion? @relation(fields: [approvedPopVersionId], references: [id])
  decision             String
  statusFrom           String?
  statusTo             String
  version              String?
  comment              String?
  userId               String
  userName             String?
  createdAt            DateTime            @default(now())

  @@index([tenantId, popId])
  @@index([tenantId, draftId])
  @@index([tenantId, decision])
}

model DocumentLifecycleEvent {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  entityType        String
  entityId          String
  relatedEntityType String?
  relatedEntityId   String?
  action            String
  statusFrom        String?
  statusTo          String?
  version           String?
  userId            String?
  userName          String?
  occurredAt        DateTime @default(now())
  metadata          Json?

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, relatedEntityType, relatedEntityId])
  @@index([tenantId, action])
  @@index([tenantId, occurredAt])
}

model CanonicalIngestionJob {
  id                  String             @id @default(cuid())
  tenantId            String
  tenant              Tenant             @relation(fields: [tenantId], references: [id])
  sourceType          String
  sourceId            String
  status              String             @default("QUEUED")
  requestedByUserId   String?
  requestedByUserName String?
  canonicalDocumentId String?
  canonicalDocument   CanonicalDocument? @relation(fields: [canonicalDocumentId], references: [id])
  startedAt           DateTime?
  finishedAt          DateTime?
  errorCode           String?
  errorMessageSafe    String?
  sourceHash          String?
  normalizedTextHash  String?
  metadata            Json?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, sourceType, sourceId])
  @@index([tenantId, canonicalDocumentId])
  @@index([tenantId, createdAt])
}

model CanonicalDocument {
  id                    String                            @id @default(cuid())
  tenantId              String
  tenant                Tenant                            @relation(fields: [tenantId], references: [id])
  kind                  String
  status                String                            @default("ACTIVE")
  title                 String
  code                  String?
  category              String?
  version               String?
  sourceType            String
  sourceId              String
  libraryItemId         String?
  libraryItem           DocumentaryLibraryItem?           @relation(fields: [libraryItemId], references: [id])
  approvedPopVersionId  String?
  approvedPopVersion    ApprovedPopVersion?               @relation(fields: [approvedPopVersionId], references: [id])
  sourceHash            String?
  normalizedTextHash    String?
  normalizedTextPreview String?
  effectiveAt           DateTime?
  obsoleteAt            DateTime?
  createdByUserId       String?
  createdByUserName     String?
  metadata              Json?
  createdAt             DateTime                          @default(now())
  updatedAt             DateTime                          @updatedAt
  ingestionJobs         CanonicalIngestionJob[]
  chunks                CanonicalChunk[]
  assistedDraftSources  AssistedPopDraftCanonicalSource[]

  @@unique([tenantId, sourceType, sourceId, version])
  @@index([tenantId, kind])
  @@index([tenantId, status])
  @@index([tenantId, libraryItemId])
  @@index([tenantId, approvedPopVersionId])
  @@index([tenantId, sourceHash])
  @@index([tenantId, updatedAt])
}

model CanonicalChunk {
  id                   String                            @id @default(cuid())
  tenantId             String
  tenant               Tenant                            @relation(fields: [tenantId], references: [id])
  canonicalDocumentId  String
  canonicalDocument    CanonicalDocument                 @relation(fields: [canonicalDocumentId], references: [id])
  chunkIndex           Int
  heading              String?
  text                 String
  tokenEstimate        Int
  semanticRole         String                            @default("UNKNOWN")
  sourceHash           String
  createdAt            DateTime                          @default(now())
  updatedAt            DateTime                          @updatedAt
  assistedDraftSources AssistedPopDraftCanonicalSource[]

  @@unique([tenantId, canonicalDocumentId, chunkIndex])
  @@index([tenantId, canonicalDocumentId])
  @@index([tenantId, sourceHash])
  @@index([tenantId, semanticRole])
}

model RagRetrievalLog {
  id                   String                            @id @default(cuid())
  tenantId             String
  tenant               Tenant                            @relation(fields: [tenantId], references: [id])
  userId               String?
  purpose              String                            @default("CANONICAL_SEARCH")
  queryPreview         String
  queryHash            String
  documentId           String?
  retrievedChunkIds    Json
  resultCount          Int
  filtersJson          Json?
  createdAt            DateTime                          @default(now())
  assistedDraftSources AssistedPopDraftCanonicalSource[]

  @@index([tenantId, createdAt])
  @@index([tenantId, purpose])
  @@index([tenantId, documentId])
  @@index([tenantId, queryHash])
}

model Quiz {
  id           String          @id @default(cuid())
  titulo       String
  descricao    String?
  popId        String          @unique
  pop          Pop             @relation(fields: [popId], references: [id])
  notaMinima   Int             @default(70)
  questoesData Json?
  ativo        Boolean         @default(true)
  tenantId     String
  tenant       Tenant          @relation(fields: [tenantId], references: [id])
  tentativas   TentativaQuiz[]
  questoes     Questao[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model Questao {
  id           String        @id @default(cuid())
  pergunta     String
  ordem        Int
  quizId       String
  quiz         Quiz          @relation(fields: [quizId], references: [id])
  alternativas Alternativa[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Alternativa {
  id        String   @id @default(cuid())
  texto     String
  correta   Boolean  @default(false)
  ordem     Int
  questaoId String
  questao   Questao  @relation(fields: [questaoId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TentativaQuiz {
  id              String      @id @default(cuid())
  quizId          String
  quiz            Quiz        @relation(fields: [quizId], references: [id])
  colaboradorId   String
  colaborador     Colaborador @relation(fields: [colaboradorId], references: [id])
  treinamentoId   String
  treinamento     Treinamento @relation(fields: [treinamentoId], references: [id])
  nota            Int?
  aprovado        Boolean     @default(false)
  codigoValidacao String?
  completadoEm    DateTime?
  acertos         Int?
  totalQuestoes   Int?
  respostasData   Json?
  respostas       Resposta[]
  certificados    Certificado[]
  createdAt       DateTime    @default(now())
}

model Certificado {
  id              String         @id @default(cuid())
  usuarioId       String
  usuarioNome     String?
  colaboradorId   String?
  colaboradorNome String?
  treinamentoId   String
  tentativaId      String?
  tentativa        TentativaQuiz? @relation(fields: [tentativaId], references: [id])
  arquivoUrl      String
  codigoValidacao String?
  dataEmissao     DateTime       @default(now())
  validade        DateTime?
  tenantId        String
  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  criadoEm        DateTime       @default(now())

  @@unique([tenantId, treinamentoId])
  @@index([tenantId, usuarioId])
  @@index([tenantId, colaboradorId])
  @@index([tenantId, validade])
}

model AlertaTreinamento {
  id             String   @id @default(cuid())
  usuarioId      String
  treinamentoId  String
  tipo           String
  mensagem       String?
  lido           Boolean  @default(false)
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  criadoEm       DateTime @default(now())

  @@unique([usuarioId, treinamentoId, tipo])
  @@index([tenantId, usuarioId, lido])
  @@index([tenantId, tipo])
  @@index([tenantId, criadoEm])
}

model Resposta {
  id              String        @id @default(cuid())
  tentativaQuizId String
  tentativaQuiz   TentativaQuiz @relation(fields: [tentativaQuizId], references: [id])
  questaoId       String
  alternativaId   String?
  correta         Boolean
  createdAt       DateTime      @default(now())
}

model Risco {
  id                    String            @id @default(cuid())
  nivelRisco            Int
  descricao             String?
  setor                 String?
  categoria             String?
  probabilidade         Int?
  impacto               Int?
  tipo                  String?
  severidade            String?
  planoAcao             String?
  responsavelPlano      String?
  prazoPlano            DateTime?
  criadoPor             String?
  criadoEm              DateTime?
  tenantId              String
  tenant                Tenant            @relation(fields: [tenantId], references: [id])
  popId                 String?
  pop                   Pop?              @relation(fields: [popId], references: [id])
  naoConformidades      NaoConformidade[] @relation("RiscoNaoConformidades")
  naoConformidadesRisco NaoConformidade[] @relation("RiscoNaoConformidadeRisco")
  auditorias            Auditoria[]
  auditoriasRisco       AuditoriaRisco[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
}

model NaoConformidade {
  id                     String    @id @default(cuid())
  codigo                 String
  titulo                 String?
  descricao              String?
  setor                  String?
  tipo                   String?
  severidade             String?
  status                 String
  origem                 String?
  dataOcorrencia         DateTime?
  dataIdentificacao      DateTime?
  reportadoPor           String?
  riscoId                String?
  risco                  Risco?    @relation("RiscoNaoConformidadeRisco", fields: [riscoId], references: [id])
  popId                  String?
  pop                    Pop?      @relation(fields: [popId], references: [id])
  loteId                 String?
  equipamentoId          String?
  colaboradorId          String?
  reclamacaoId           String?
  criadoPorId            String?
  criadoPorNome          String?
  causaRaiz              String?
  investigadoPorId       String?
  investigadoPorNome     String?
  dataInvestigacao       DateTime?
  acoesCorretivas        String?
  planoAcao              String?
  responsavelCapaId      String?
  responsavelCapaNome    String?
  prazoCorrecao          DateTime?
  prazoImplementacao     DateTime?
  exigeAprovacaoRt       Boolean   @default(false)
  aprovadoPorRtId        String?
  aprovadoPorRtNome      String?
  dataAprovacaoRt        DateTime?
  dataImplementacao      DateTime?
  implementadoPorId      String?
  implementadoPorNome    String?
  verificacaoEfetividade String?
  dataVerificacao        DateTime?
  verificadoPorId        String?
  verificadoPorNome      String?
  fechadoPorId           String?
  fechadoPorNome         String?
  dataFechamento         DateTime?
  observacaoFechamento   String?
  sugestaoTreinamento    Boolean   @default(false)
  sugestaoRevisaoPop     Boolean   @default(false)
  comentarios            Json?
  historico              Json?
  tenantId               String
  tenant                 Tenant    @relation(fields: [tenantId], references: [id])
  riscos                 Risco[]   @relation("RiscoNaoConformidades")
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, severidade])
  @@index([tenantId, origem])
  @@index([tenantId, createdAt])
}

model Auditoria {
  id              String           @id @default(cuid())
  status          String
  dataInicio      DateTime?
  resultado       String?
  tenantId        String
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  riscos          Risco[]
  auditoriasRisco AuditoriaRisco[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model AuditoriaRisco {
  id           String     @id @default(cuid())
  titulo       String
  descricao    String?
  tipo         String?
  severidade   String?
  status       String
  dataInicio   DateTime?
  dataFim      DateTime?
  auditorId    String?
  auditorLider String?
  auditores    Json?
  setores      Json?
  pops         Json?
  criterios    Json?
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  auditoria    Auditoria? @relation(fields: [auditoriaId], references: [id])
  auditoriaId  String?
  risco        Risco?     @relation(fields: [riscoId], references: [id])
  riscoId      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Norma {
  id              String        @id @default(cuid())
  codigo          String
  numero          String?
  titulo          String
  descricao       String?
  tipo            String?
  versao          String?
  dataAtualizacao DateTime?
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  alertas         AlertaNorma[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model AlertaNorma {
  id         String    @id @default(cuid())
  tipo       String
  severidade String?
  prioridade Int?
  descricao  String?
  status     String
  dataAlerta DateTime?
  normaId    String
  norma      Norma     @relation(fields: [normaId], references: [id])
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model VerificacaoPratica {
  id              String      @id @default(cuid())
  data            DateTime
  dataAgendamento DateTime?
  duracaoEstimada Int?
  observacoes     String?
  status          String
  nota            Int?
  aprovado        Boolean?
  supervisor      String?
  treinamentoId   String
  treinamento     Treinamento @relation(fields: [treinamentoId], references: [id])
  colaboradorId   String
  colaborador     Colaborador @relation(fields: [colaboradorId], references: [id])
  popId           String?
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Documento {
  id         String   @id @default(cuid())
  codigo     String
  titulo     String
  tipo       String
  categoria  String?
  versao     String?
  conteudo   String?
  arquivoUrl String?
  popId      String?
  pop        Pop?     @relation(fields: [popId], references: [id])
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Fornecedor {
  id             String         @id @default(cuid())
  nome           String
  cnpj           String?
  contato        String?
  email          String?
  telefone       String?
  endereco       String?
  observacoes    String?
  status         String         @default("ATIVO")
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  materiasPrimas MateriaPrima[]
  lotes          Lote[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model MateriaPrima {
  id                String            @id @default(cuid())
  codigo            String
  nome              String
  descricao         String?
  casNumber         String?
  dci               String?
  categoria         String?
  unidadeMedida     String?
  estoqueMinimo     Float?
  especificacoes    String?
  certificadoUrl    String?
  certificadoNome   String?
  certificadoPublic Boolean           @default(false)
  status            String            @default("ATIVO")
  fornecedorId      String
  fornecedor        Fornecedor        @relation(fields: [fornecedorId], references: [id])
  tenantId          String
  tenant            Tenant            @relation(fields: [tenantId], references: [id])
  lotes             Lote[]
  pops              PopMateriaPrima[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model PopMateriaPrima {
  id             String       @id @default(cuid())
  popId          String
  pop            Pop          @relation(fields: [popId], references: [id])
  materiaPrimaId String
  materiaPrima   MateriaPrima @relation(fields: [materiaPrimaId], references: [id])
  quantidade     Float?
  observacoes    String?
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  createdAt      DateTime     @default(now())
}

model Lote {
  id                 String       @id @default(cuid())
  numeroLote         String
  loteInterno        String?
  dataFabricacao     DateTime?
  dataValidade       DateTime?
  dataRecebimento    DateTime?
  quantidade         Float?
  quantidadeAtual    Float?
  precoUnitario      Float?
  notaFiscal         String?
  certificadoUrl     String?
  certificadoNome    String?
  certificadoPublic  Boolean      @default(false)
  laudoUrl           String?
  laudoNome          String?
  laudoPublic        Boolean      @default(false)
  analises           Json?
  observacoes        String?
  statusRisco        String?
  validadeRisco      DateTime?
  classificacaoRisco String?
  armazenamento      String?
  condicoes          String?
  localizacao        String?
  status             String       @default("ATIVO")
  materiaPrimaId     String
  materiaPrima       MateriaPrima @relation(fields: [materiaPrimaId], references: [id])
  fornecedorId       String
  fornecedor         Fornecedor   @relation(fields: [fornecedorId], references: [id])
  tenantId           String
  tenant             Tenant       @relation(fields: [tenantId], references: [id])
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  action    String
  entity    String
  entityId  String?
  userId    String?
  userName  String?
  details   Json?
  createdAt DateTime @default(now())
}

model AuditoriaFiscalizacao {
  id                  String   @id @default(cuid())
  tenantId            String
  tenant              Tenant   @relation(fields: [tenantId], references: [id])
  status              String   @default("ATIVO")
  dataGeracao         DateTime @default(now())
  dataExpiracao       DateTime
  qrCode              String?
  codigoAcesso        String?
  responsaveis        Json?
  masterListPOPs      Json?
  certificados        Json?
  cronogramaValidades Json?
  acessos             Json?
  anotacoes           Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

