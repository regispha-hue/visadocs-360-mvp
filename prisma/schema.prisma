generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OPERADOR
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  role      UserRole @default(OPERADOR)
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tenant {
  id               String   @id @default(cuid())
  nome             String
  cnpj             String?
  status           String   @default("ATIVO")
  subscriptionStatus String @default("ATIVO")
  logoUrl          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  users            User[]
  pops             Pop[]
  colaboradores    Colaborador[]
  treinamentos     Treinamento[]
  auditLogs        AuditLog[]
}

model Pop {
  id        String   @id @default(cuid())
  codigo    String   @unique
  titulo    String
  setor     String?
  status    String   @default("ATIVO")
  conteudo  String?
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  treinamentos Treinamento[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Colaborador {
  id        String   @id @default(cuid())
  nome      String
  email     String?
  status    String   @default("ATIVO")
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  treinamentos Treinamento[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Treinamento {
  id             String   @id @default(cuid())
  popId          String
  pop            Pop      @relation(fields: [popId], references: [id])
  colaboradorId  String
  colaborador    Colaborador @relation(fields: [colaboradorId], references: [id])
  status         String   @default("PENDENTE")
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  action    String
  entity    String
  entityId  String?
  userId    String?
  userName  String?
  details   Json?
  createdAt DateTime @default(now())
}
